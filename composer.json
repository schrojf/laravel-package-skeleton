{
    "name": "vendor-name/package-name",
    "description": "This is my package package-name",
    "keywords": [
        "vendor-name",
        "laravel",
        "package-name"
    ],
    "homepage": "https://github.com/vendor-name/package-name",
    "license": "MIT",
    "authors": [
        {
            "name": "Forename Surname",
            "email": "author@example.org",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0||^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "1.27.1",
        "mockery/mockery": "^1.0",
        "orchestra/pest-plugin-testbench": "^2.0||^3.0",
        "orchestra/testbench": "^8.34.0||^9.12.0||^10.0",
        "orchestra/testbench-core": "^8.0||^9.0||^10.0",
        "pestphp/pest": "^2.30.0||^3.0",
        "pestphp/pest-plugin-arch": "^2.0||^3.0",
        "pestphp/pest-plugin-laravel": "^2.0||^3.0",
        "phpstan/phpstan": "^2.1",
        "ramsey/uuid": "^4.0",
        "spatie/laravel-ignition": "^2.0",
        "symfony/mime": "^6.0||^7.0",
        "symfony/var-dumper": "^6.0||^7.0"
    },
    "autoload": {
        "psr-4": {
            "VendorName\\PackageName\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "App\\": "workbench/app/",
            "Database\\Factories\\": "workbench/database/factories/",
            "Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@build"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@php vendor/bin/testbench package:sync-skeleton --ansi",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "ci": [
            "@composer test",
            "@composer lint"
        ],
        "lint": [
            "@php vendor/bin/phpstan --memory-limit=-1 --verbose",
            "@php vendor/bin/pint --config=pint.ci.json --cache-file=.pint.ci.cache",
            "@php vendor/bin/pint --cache-file=.pint.cache"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": [
            "@php vendor/bin/testbench package:purge-skeleton",
            "@php vendor/bin/pest"
        ],
        "test-coverage": [
            "@php vendor/bin/testbench package:purge-skeleton",
            "@php vendor/bin/pest --coverage"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "VendorName\\PackageName\\PackageNameServiceProvider"
            ],
            "aliases": {
                "PackageName": "VendorName\\PackageName\\Facades\\PackageName"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
